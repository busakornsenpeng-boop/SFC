  'ซ่อมเสร็จ':    { color: '#43A047', title: '✅ ซ่อมเสร็จสิ้น!',           icon: '🟢' },
  'ซ่อมเสร็จแล้ว':{ color: '#43A047', title: '✅ ซ่อมเสร็จสิ้น!',           icon: '🟢' },
